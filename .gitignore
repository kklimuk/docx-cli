*~

# OS
.DS_Store
.DS_STORE
Thumbs.db

# Temp
tmp/
temp/
*.tmp
# Word owner-lock files (appear when a fixture is opened in Word for verification)
~$*

# Local sample / scratch docs
scripts/data/
# docs/ is the published GitHub Pages site (committed). Internal review notes go in
# docs/_notes/ — kept out of git, and out of the Jekyll build too (a leading-underscore
# dir is ignored by Jekyll natively). Local Jekyll build output is ignored as well.
docs/_notes/
docs/_site/
docs/.jekyll-cache/
docs/.jekyll-metadata

# worktrees
.worktrees/

__pycache__