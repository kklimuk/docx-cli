{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git worktree:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(bunx tsc *)",
      "Bash(bun run check)",
      "Bash(bun run test*)",
      "Bash(bunx biome *)",
      "Bash(bun src/index.ts *)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push origin --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin -f:*)"
    ]
  }
}
