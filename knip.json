{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/core/jsx/jsx-runtime.ts",
		"src/core/jsx/jsx-dev-runtime.ts",
		"scripts/*.{ts,tsx}",
		"tests/fixtures/setup/**/*.{ts,tsx}",
		"tests/**/*.test.{ts,tsx}"
	],
	"project": [
		"src/**/*.{ts,tsx}",
		"scripts/**/*.{ts,tsx}",
		"tests/**/*.{ts,tsx}"
	],
	"ignoreDependencies": ["@core/jsx"],
	"ignoreExportsUsedInFile": true
}
